# Deployer Configuration
#
# Copy this file to .env and customize as needed.

# =============================================================================
# Environments Directory (REQUIRED)
# =============================================================================
#
# Path to the directory containing environment configs. Each environment
# (e.g., myapp-staging, myapp-production) should be a subdirectory here.
#
# This is typically a separate private repository since environment configs
# may contain sensitive infrastructure details.
#
DEPLOYER_ENVIRONMENTS_DIR=~/code/deployer-environments

# =============================================================================
# Deployer Repo Directory (RECOMMENDED)
# =============================================================================
#
# Path to this deployer repo. Used in documentation and manual symlink
# commands (e.g., ln -s $DEPLOYER_DIR/environments/deployer.tf deployer.tf).
# Set this in your shell profile or .env so commands from the docs work
# without assuming a specific directory layout.
#
DEPLOYER_DIR=~/code/deployer

# =============================================================================
# AWS Profiles
# =============================================================================
#
# AWS profiles are configured per-environment in each config.toml file:
#
#   [aws]
#   deploy_profile = "deployer-app"      # for deploy.py
#   infra_profile = "deployer-infra"     # for tofu.sh
#   cognito_profile = "deployer-cognito" # for cognito.py
#
# This allows different environments to use different AWS accounts/profiles.
# See docs/GETTING-STARTED.md for IAM setup instructions.
#
# You can override any profile with AWS_PROFILE environment variable:
#   AWS_PROFILE=admin ./bin/tofu.sh plan myapp-staging
